# Server Port
PORT=3000

# Database Configuration
# Set DB_TYPE to 'sqlite' for zero-config local runs, or 'mysql' for production MySQL
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=uptime_monitor

# JWT Configuration
JWT_SECRET=super_secret_portfolio_key_change_me_in_production
JWT_EXPIRES_IN=7d

# SMTP Configuration (e.g. Mailtrap, Gmail, etc.)
# For Mailtrap or similar dev servers:
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Email Alert Customizations
EMAIL_FROM="API Uptime Monitor <alerts@uptime-monitor.local>"
EMAIL_ALERT_RECIPIENT=your_alert_email@example.com
